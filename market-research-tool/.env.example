PORT=3000
SESSION_SECRET=change-this-to-a-long-random-string

# Refresh intervals, in minutes, for the background data/signal scheduler.
REFRESH_MINUTES_SHARES=15
REFRESH_MINUTES_CRYPTO=10

# Optional: SMTP details for email alerts (FR-044). If left blank, email alerts are
# skipped and only in-app alerts are shown - nothing else needs these to work.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
ALERT_EMAIL_FROM=
ALERT_EMAIL_TO=
