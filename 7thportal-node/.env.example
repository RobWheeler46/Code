# --- 7thPortal -----------------------------------------------------------------
# Copy to .env for local development. On Railway set these as service variables.

PORT=8050

# Signs the application session cookie. Long random string.
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-this-to-a-long-random-string

# 32-byte key (hex or base64) used to encrypt stored OSM tokens at rest.
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# If unset, a key file is generated in data/ on first boot and a warning is logged.
TOKEN_ENCRYPTION_KEY=

# Where the SQLite database and uploaded documents live. On Railway, point a
# persistent volume here (e.g. /app/data) so redeploys keep data and files.
DATA_DIR=

# Seed demo accounts (admin/leader/parent) on first boot so the app is usable
# before OSM is configured. Set to false once real accounts exist.
SEED_DEMO_USERS=true

# --- OSM developer application --------------------------------------------------
# Created through OSM's Developer Tools. The secret never leaves the server and is
# never sent to the browser. Leave blank to run with local logins only - the OSM
# button on the login page is shown as unavailable until these are set.
OSM_CLIENT_ID=
OSM_CLIENT_SECRET=

# Must exactly match the callback registered against the OSM developer application.
# HTTPS is required except for http://localhost.
OSM_CALLBACK_URL=http://localhost:8050/auth/osm/callback

# OSM endpoints. Defaults are community-documented, not an official spec - keep
# them configurable.
OSM_AUTHORIZE_URL=https://www.onlinescoutmanager.co.uk/oauth/authorize
OSM_TOKEN_URL=https://www.onlinescoutmanager.co.uk/oauth/token
OSM_RESOURCE_URL=https://www.onlinescoutmanager.co.uk/oauth/resource
OSM_SCOPES=section:member:read

# Comma-separated OSM emails and/or OSM user ids granted the Admin role on login.
# Everyone else who logs in through OSM is treated as a Leader.
ADMIN_EMAILS=
ADMIN_OSM_USER_IDS=

# Session inactivity timeout in minutes.
SESSION_IDLE_MINUTES=120
