# Defense in depth: this folder holds the SQLite database and uploaded photos.
# It should live outside the web root entirely (see README "Deployment layout").
# This file only helps if a host forces it to be web-accessible anyway.
<IfModule mod_authz_core.c>
  Require all denied
</IfModule>
<IfModule !mod_authz_core.c>
  Order deny,allow
  Deny from all
</IfModule>
