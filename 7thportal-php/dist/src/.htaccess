# Defense in depth: PHP source should live outside the web root entirely
# (see README "Deployment layout"). This only helps if a host forces it to be
# web-accessible anyway - it should never be reachable in normal deployment.
<IfModule mod_authz_core.c>
  Require all denied
</IfModule>
<IfModule !mod_authz_core.c>
  Order deny,allow
  Deny from all
</IfModule>
