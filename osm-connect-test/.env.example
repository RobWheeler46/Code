# --- OSM Connect Test Harness -------------------------------------------------
# Copy to .env for local development. On Railway set these as service variables.

PORT=3000

# Signs the application session cookie. Long random string.
SESSION_SECRET=change-this-to-a-long-random-string

# 32-byte key, hex or base64, used to encrypt OSM access/refresh tokens at rest
# (FR-AUTH-012 / FR-SEC-003). Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# If unset, a key file is generated in data/ on first boot and the app logs a warning.
TOKEN_ENCRYPTION_KEY=

# --- OSM developer application ------------------------------------------------
# Created through OSM's Developer Tools. The secret is never displayed once set
# and is never sent to the browser (FR-CONFIG-002 / FR-AUTH-010).
OSM_CLIENT_ID=
OSM_CLIENT_SECRET=

# Must exactly match the callback registered against the OSM developer application.
# HTTPS is required except for http://localhost (FR-CONFIG-004).
OSM_CALLBACK_URL=http://localhost:3000/oauth/callback

# OSM endpoints. Defaults below are based on community-maintained documentation and
# are NOT an officially supported specification - keep them configurable (FRD 7.1).
OSM_AUTHORIZE_URL=https://www.onlinescoutmanager.co.uk/oauth/authorize
OSM_TOKEN_URL=https://www.onlinescoutmanager.co.uk/oauth/token
OSM_API_BASE=https://www.onlinescoutmanager.co.uk
OSM_SCOPES=section:member:read section:programme:read section:event:read section:attendance:read section:badge:read

# Hostnames the server is permitted to call. Anything else is refused
# (FR-SEC-010 / FR-SEC-011). Comma separated.
OSM_ALLOWED_HOSTS=www.onlinescoutmanager.co.uk,onlinescoutmanager.co.uk

# First-run setup. When set (16+ characters recommended), the /setup.html screen lets
# someone holding this key enter the OSM client id, secret and endpoints from the
# browser BEFORE anyone has connected - breaking the "need admin to configure, need
# config to sign in" deadlock. Leave unset once configuration is complete to close it.
# Generate with:
#   node -e "console.log(require('crypto').randomBytes(24).toString('base64url'))"
SETUP_KEY=

# --- Application administrators ------------------------------------------------
# Comma-separated OSM email addresses and/or OSM user ids granted the Application
# Administrator role on connection. Everyone else is a Tester.
ADMIN_EMAILS=
ADMIN_OSM_USER_IDS=

# Comma-separated OSM email addresses granted the Developer role (expanded diagnostics).
DEVELOPER_EMAILS=

# --- Behaviour ----------------------------------------------------------------
REQUEST_TIMEOUT_MS=15000
MAX_AUTOMATIC_RETRIES=1
LOCAL_RATE_LIMIT_THRESHOLD=60
MAX_RESPONSE_BYTES=1048576
DIAGNOSTIC_RETENTION_DAYS=30
SESSION_IDLE_MINUTES=60

# Allows tests classified as possibly returning young people's information to be
# enabled by an administrator. Leave false outside development (FRD 12.7).
ALLOW_PERSONAL_DATA_TESTS=false
