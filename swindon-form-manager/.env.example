PORT=3000
SESSION_SECRET=change-this-to-a-long-random-string

# OSM API application credentials (from your OSM API access application - the same kind
# used by the osm-badges project). Required for login: users sign in with their own OSM
# email/password, which the server exchanges for a token via OSM's oauth/token endpoint.
OSM_CLIENT_ID=your_osm_client_id_here
OSM_CLIENT_SECRET=your_osm_client_secret_here

# OSM email address of the first administrator. Pre-registered by the seed script so they
# can log in as an admin straight away using their normal OSM password.
ADMIN_EMAIL=admin@7thswindon.org.uk
