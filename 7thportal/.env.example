# OSM OAuth2 app credentials (register at https://www.onlinescoutmanager.co.uk -> My Account -> My Apps)
# Same credential model already validated in the osm-badges-2025 tool.
OSM_CLIENT_ID=your_client_id_here
OSM_CLIENT_SECRET=your_client_secret_here
OSM_REDIRECT_URI=http://localhost:3040/auth/osm/callback

# Session cookie signing secret - set a long random value in production
SESSION_SECRET=dev-only-secret-change-me

PORT=3040
NODE_ENV=development

# Demo mode lets anyone log in as a sample parent/leader/admin with fake OSM data,
# so the app can be explored before OSM credentials are configured. Leave this off
# once real child data is in play - see README "Demo mode" section.
ALLOW_DEMO_MODE=true

# Optional: SMTP for parent account setup invite emails. If unset, invite links
# are shown to the admin to copy/send manually instead.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
INVITE_EMAIL_FROM=
