PORT=3000
SESSION_SECRET=change-this-to-a-long-random-string

# First super administrator, created by the seed script. Password is randomly generated
# and printed once when the seed script runs (see README) - change it after first login.
ADMIN_EMAIL=admin@example.com

# DEV/DEMO ONLY - authentication bypass. When set to exactly "true", the app grants full
# administrator access to EVERY visitor with NO login required (acting as ADMIN_EMAIL, or the
# highest-privilege admin if that is unset). Leave unset/false everywhere except local dev or a
# throwaway demo. NEVER enable on the production/Railway deployment - it exposes all content and
# user management to the public. Default: off.
ADMIN_AUTOLOGIN=false
